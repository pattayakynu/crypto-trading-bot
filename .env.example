# ═══════════════════════════════════════════════════════════════
#  Crypto Trading Bot — environment variables
#  Copy to .env and fill in real values before running.
# ═══════════════════════════════════════════════════════════════

# ── Binance ─────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
# Set to false to use real Binance (default: true = testnet)
BINANCE_TESTNET=true

# ── AI APIs ──────────────────────────────────────────────────────
# Claude Haiku — used in the dual-LLM advisor and daily reports
CLAUDE_API_KEY=your_anthropic_api_key_here
# DeepSeek V3 — used in the dual-LLM advisor and daily reports
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated list of allowed Telegram user IDs (get via @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# ── Web Dashboard ────────────────────────────────────────────────
# Secret key for the FastAPI backend (X-API-Key header)
WEB_API_KEY=change-me-to-something-random

# URL the *browser* uses to reach the backend
# If running locally: http://localhost:8000
# If deployed:        https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Redis ────────────────────────────────────────────────────────
# Only change if you run Redis on a non-default host/port
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=bot:

# ── Engine tuning (optional) ────────────────────────────────────
# How often to scan each pair for signals (seconds)
SCAN_INTERVAL_SECONDS=300
# UTC times to send daily reports (comma-separated HH:MM)
REPORT_TIMES=07:00,12:00,17:00,22:00
